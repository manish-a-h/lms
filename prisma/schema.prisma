// Leave Management System — Full Prisma Schema
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum Role {
  employee
  manager
  hr_admin
}

enum LeaveStatus {
  pending
  approved
  rejected
  cancelled
}

enum ApprovalAction {
  approved
  rejected
}

enum DayTime {
  full_day
  forenoon
  afternoon
}

enum SalaryComponentType {
  earning
  deduction
}

enum TokenPurpose {
  session
  reset
}

// ─────────────────────────────────────────────
// User / Profile
// ─────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  nitteEmail   String?  @unique
  passwordHash String
  name         String
  role         Role     @default(employee)

  // Profile fields
  avatarUrl    String?
  department   String?
  designation  String?
  institution  String?
  panNo        String?
  pfUan        String?
  bankAcctNo   String?
  contactNo    String?
  dob          DateTime?
  dateOfJoin   DateTime?
  isActive     Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  leaveRequests       LeaveRequest[]
  leaveBalances       LeaveBalance[]
  approvalLogs        ApprovalLog[]    @relation("ManagerLogs")
  managerAssignments  TeamAssignment[] @relation("ManagerAssignments")
  employeeAssignments TeamAssignment[] @relation("EmployeeAssignments")
  activityLogs        ActivityLog[]    @relation("ActorActivityLogs")
  salaryComponents    SalaryComponent[]
  salarySlips         SalarySlip[]
  refreshTokens       RefreshToken[]
  notifications       Notification[]
}

// ─────────────────────────────────────────────
// Leave Types
// ─────────────────────────────────────────────

model LeaveType {
  id              String  @id @default(cuid())
  name            String  @unique
  maxDaysPerYear  Int
  carryForward    Boolean @default(false)
  description     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  leaveRequests LeaveRequest[]
  leaveBalances LeaveBalance[]
}

// ─────────────────────────────────────────────
// Leave Requests
// ─────────────────────────────────────────────

model LeaveRequest {
  id           String      @id @default(cuid())
  userId       String
  leaveTypeId  String
  startDate    DateTime
  endDate      DateTime
  dayTime      DayTime     @default(full_day)
  noOfDays     Float
  reason       String
  dutyIncharge String?
  status       LeaveStatus @default(pending)
  appliedOn    DateTime    @default(now())
  comments     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  leaveType    LeaveType     @relation(fields: [leaveTypeId], references: [id], onDelete: Restrict)
  approvalLogs ApprovalLog[]
}

// ─────────────────────────────────────────────
// Leave Balances
// ─────────────────────────────────────────────

model LeaveBalance {
  id          String @id @default(cuid())
  userId      String
  leaveTypeId String
  year        Int
  totalDays   Float
  usedDays    Float  @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Restrict)

  @@unique([userId, leaveTypeId, year])
}

// ─────────────────────────────────────────────
// Approval Logs
// ─────────────────────────────────────────────

model ApprovalLog {
  id         String         @id @default(cuid())
  requestId  String
  managerId  String?
  action     ApprovalAction
  comment    String?
  actionDate DateTime       @default(now())

  // Relations
  request LeaveRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  manager User?        @relation("ManagerLogs", fields: [managerId], references: [id], onDelete: SetNull)
}

model TeamAssignment {
  id         String   @id @default(cuid())
  managerId  String
  employeeId String
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  manager  User @relation("ManagerAssignments", fields: [managerId], references: [id], onDelete: Cascade)
  employee User @relation("EmployeeAssignments", fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([managerId, employeeId])
  @@index([employeeId, active])
}

model ActivityLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  entityType String
  entityId   String?
  message    String
  metadata   Json?
  createdAt  DateTime @default(now())

  actor User? @relation("ActorActivityLogs", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId, createdAt])
  @@index([entityType, createdAt])
}

// ─────────────────────────────────────────────
// Salary
// ─────────────────────────────────────────────

model SalaryComponent {
  id            String              @id @default(cuid())
  userId        String
  componentName String
  amount        Decimal             @db.Decimal(12, 2)
  type          SalaryComponentType

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SalarySlip {
  id          String   @id @default(cuid())
  userId      String
  month       Int      // 1–12
  year        Int
  grossSalary Decimal  @db.Decimal(12, 2)
  netSalary   Decimal  @db.Decimal(12, 2)
  generatedAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  lineItems SalarySlipLineItem[]

  @@unique([userId, month, year])
}

model SalarySlipLineItem {
  id              String              @id @default(cuid())
  salarySlipId    String
  componentName   String
  amount          Decimal             @db.Decimal(12, 2)
  type            SalaryComponentType

  // Relations
  salarySlip SalarySlip @relation(fields: [salarySlipId], references: [id], onDelete: Cascade)

  @@index([salarySlipId])
}

// ─────────────────────────────────────────────
// Holidays
// ─────────────────────────────────────────────

model Holiday {
  id         String   @id @default(cuid())
  name       String
  date       DateTime
  isOptional Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// Refresh Tokens
// ─────────────────────────────────────────────

model RefreshToken {
  id        String       @id @default(cuid())
  userId    String
  tokenHash String       @unique
  purpose   TokenPurpose @default(session)
  expiresAt DateTime
  revoked   Boolean      @default(false)

  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose, revoked, expiresAt])
}

// ─── Notifications ────────────────────────────────────────────────────────────

enum NotificationType {
  LEAVE_SUBMITTED
  LEAVE_APPROVED
  LEAVE_REJECTED
  LEAVE_CANCELLED
  LEAVE_REMINDER
  SYSTEM
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
}
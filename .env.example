# --- Database ---------------------------------------------------------------
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/lms_db"

# --- Auth (JWT) -------------------------------------------------------------
# Generate strong secrets: openssl rand -base64 64
JWT_SECRET="change-me-long-random-string-for-access-tokens"
JWT_REFRESH_SECRET="change-me-different-long-random-string-for-refresh"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES_DAYS="7"

# --- Email (SMTP) ------------------------------------------------------------
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="HRMS Portal <noreply@hrms.local>"

# --- App ---------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="HRMS Portal"

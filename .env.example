# ─── Database ───────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/lms_db"

# ─── Auth / JWT ─────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-jwt-key"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES_DAYS="7"

# ─── App ────────────────────────────────────────────────────
APP_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"
NODE_ENV="development"

# ─── Microsoft Teams / Entra ID SSO ─────────────────────────
TEAMS_CLIENT_ID="your-entra-app-client-id"
TEAMS_CLIENT_SECRET="your-entra-app-client-secret"
TEAMS_TENANT_ID="organizations"
TEAMS_REDIRECT_URI="http://localhost:3000/api/auth/teams/callback"
TEAMS_ALLOWED_DOMAINS=""
TEAMS_AUTO_PROVISION="true"
TEAMS_HR_EMAILS="hr1@example.com,hr2@example.com"
TEAMS_HR_WEBHOOK_URL=""

# ─── Email (SMTP) ────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="LMS System <no-reply@yourdomain.com>"

# ─── Cron / Scheduling ───────────────────────────────────────
CRON_SECRET="your-cron-secret-for-api-protection"